rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ==========================================
    // HELPER FUNCTIONS
    // ==========================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/admin/$(request.auth.uid));
    }

    function isDriver() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/drivers/$(request.auth.uid));
    }

    function isCustomer() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function hasValidTimestamps() {
      return request.resource.data.keys().hasAll(['createdAt', 'updatedAt']);
    }

    // ==========================================
    // USER COLLECTIONS
    // ==========================================

    // Customers
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && hasValidTimestamps();
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // Drivers
    match /drivers/{driverId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(driverId) && hasValidTimestamps();
      allow update: if isOwner(driverId) || isAdmin();
      allow delete: if isAdmin();
    }

    // Admin/Employees
    match /admin/{adminId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ==========================================
    // BOOKING COLLECTIONS
    // ==========================================

    // Cab bookings
    match /bookings/{bookingId} {
      allow read: if isAuthenticated() && (
        resource.data.customerId == request.auth.uid ||
        resource.data.driverId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isCustomer() && hasValidTimestamps() &&
        request.resource.data.customerId == request.auth.uid;
      allow update: if isAuthenticated() && (
        resource.data.customerId == request.auth.uid ||
        resource.data.driverId == request.auth.uid ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // Intercity rides (same rules as bookings)
    match /intercity_ride/{rideId} {
      allow read: if isAuthenticated() && (
        resource.data.customerId == request.auth.uid ||
        resource.data.driverId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isCustomer() && hasValidTimestamps();
      allow update: if isAuthenticated() && (
        resource.data.customerId == request.auth.uid ||
        resource.data.driverId == request.auth.uid ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // Parcel rides
    match /parcel_ride/{rideId} {
      allow read: if isAuthenticated() && (
        resource.data.customerId == request.auth.uid ||
        resource.data.driverId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isCustomer() && hasValidTimestamps();
      allow update: if isAuthenticated() && (
        resource.data.customerId == request.auth.uid ||
        resource.data.driverId == request.auth.uid ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // Rental rides
    match /rental_ride/{rideId} {
      allow read: if isAuthenticated() && (
        resource.data.customerId == request.auth.uid ||
        resource.data.driverId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isCustomer() && hasValidTimestamps();
      allow update: if isAuthenticated() && (
        resource.data.customerId == request.auth.uid ||
        resource.data.driverId == request.auth.uid ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // ==========================================
    // FINANCIAL COLLECTIONS
    // ==========================================

    // Wallet transactions
    match /wallet_transaction/{txnId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow create: if isAuthenticated(); // Created by Cloud Functions ideally
      allow update: if isAdmin();
      allow delete: if false; // Never delete financial records
    }

    // Withdrawal history
    match /withdrawal_history/{withdrawId} {
      allow read: if isAuthenticated() && (
        resource.data.driverId == request.auth.uid || isAdmin()
      );
      allow create: if isDriver();
      allow update: if isAdmin(); // Only admin approves/rejects
      allow delete: if false;
    }

    // Bank details
    match /bank_details/{bankId} {
      allow read: if isAuthenticated() && (
        resource.data.driverId == request.auth.uid || isAdmin()
      );
      allow create: if isDriver();
      allow update: if isAuthenticated() && (
        resource.data.driverId == request.auth.uid || isAdmin()
      );
      allow delete: if isAuthenticated() && (
        resource.data.driverId == request.auth.uid
      );
    }

    // ==========================================
    // CONFIGURATION (Read-only from clients)
    // ==========================================

    // Settings (payment keys, app config, commission)
    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Vehicle types, brands, models
    match /vehicle_type/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /vehicle_brand/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /vehicle_model/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Zones
    match /zones/{zoneId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Rental packages
    match /rental_packages/{packageId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Tax
    match /country_tax/{taxId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Currencies
    match /currencies/{currencyId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Documents (driver document requirements)
    match /documents/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ==========================================
    // CONTENT COLLECTIONS
    // ==========================================

    // Banners
    match /banner/{bannerId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Coupons
    match /coupon/{couponId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Onboarding screens
    match /onboarding_screen/{screenId} {
      allow read: if true; // Public — needed before auth
      allow write: if isAdmin();
    }

    // Languages
    match /languages/{langId} {
      allow read: if true; // Public — needed before auth
      allow write: if isAdmin();
    }

    // Email templates
    match /email_template/{templateId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ==========================================
    // COMMUNICATION
    // ==========================================

    // Chat (nested: chat/{userId}/inbox/{otherUserId} and chat/{userId}/{otherUserId}/{msgId})
    match /chat/{userId}/{document=**} {
      allow read: if isAuthenticated() && (
        request.auth.uid == userId || isAdmin()
      );
      allow write: if isAuthenticated();
    }

    // Notifications
    match /notification/{notifId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
    }

    // Admin broadcast notifications
    match /notification_from_admin/{notifId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ==========================================
    // SUPPORT & SAFETY
    // ==========================================

    // Support reasons
    match /support_reason/{reasonId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Support tickets
    match /support_ticket/{ticketId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow delete: if isAdmin();
    }

    // Help support tickets
    match /help_support_ticket/{ticketId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // SOS alerts
    match /sos_alerts/{alertId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow create: if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if false; // Never delete SOS records
    }

    // ==========================================
    // SUBSCRIPTIONS & REFERRALS
    // ==========================================

    // Subscription plans
    match /subscription_plans/{planId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Subscription history
    match /subscription_history/{historyId} {
      allow read: if isAuthenticated() && (
        resource.data.driverId == request.auth.uid || isAdmin()
      );
      allow create: if isDriver();
      allow update: if isAdmin();
      allow delete: if false;
    }

    // Referrals
    match /referral/{referralId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow create: if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if false;
    }

    // Loyalty point transactions
    match /loyalty_point_transaction/{txnId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow create: if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ==========================================
    // ACCESS CONTROL
    // ==========================================

    // Role permissions
    match /role_permissions/{roleId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ==========================================
    // APP VERSION (Force Update)
    // ==========================================

    match /app_version/{platform} {
      allow read: if true; // Public — needed before auth
      allow write: if isAdmin();
    }

    // ==========================================
    // AUDIT LOG (Immutable)
    // ==========================================

    match /audit_log/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated(); // Cloud Functions preferred
      allow update: if false; // Immutable
      allow delete: if false; // Immutable
    }
  }
}
